    "generate:biome-portraits": "node scripts/generate-biome-portraits.mjs",
    "generate:enclosure-portraits": "node scripts/generate-enclosure-portraits.mjs",
    "import:enclosure-portraits": "node scripts/import-enclosure-portraits.mjs",
    "vectorize:chibi": "node scripts/vectorize-chibi.mjs --demo",
