# Fins de ligne normalisées en LF pour tout le texte versionné.
# Corrige les warnings Git sous Windows (autocrlf + fichiers LF).
* text=auto eol=lf

# Scripts Windows — CRLF attendu par l’OS
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binaires — ne pas convertir
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp3 binary
*.ogg binary
*.wav binary
*.zip binary
*.gz binary
*.pdf binary
*.wasm binary
