# Copier vers deploy/stable/.env.stable.local (non versionné)
STABLE_HOST=0.0.0.0
STABLE_PORT=8787
STABLE_AUTH_USERS=metashine:kumiko,kumiko:metashine
# Legacy (optionnel si STABLE_AUTH_USERS est defini) :
# STABLE_AUTH_USER=Joueur
# STABLE_AUTH_PASS=change-me-maintenant
# Requêtes GET/HEAD max par IP par minute
STABLE_RATE_LIMIT_PER_MIN=240
# Échecs auth max par IP par minute (anti brute-force)
STABLE_AUTH_FAIL_LIMIT=20
# HTTPS avec certificat auto-signé (1=oui, 0=HTTP seulement)
STABLE_TLS=1
# Chemins optionnels (défaut : deploy/stable/certs/cert.pfx)
# STABLE_TLS_PFX=
STABLE_CLOUD_SAVES=1
STABLE_SINGLE_SESSION=1
STABLE_SESSION_TIMEOUT_MIN=5
# Gouverneur ressources (lanceur) — plafond 20 %, minimum ~10 % via affinite CPU
# Mettre 0 si le PC rame (évite les sondes PowerShell périodiques)
STABLE_RESOURCE_GOVERNOR=1
STABLE_CPU_MAX_PCT=20
STABLE_CPU_MIN_PCT=10
STABLE_MEM_MAX_PCT=20
# Intervalle entre deux mesures (ms) — 15000 = plus léger que 5000
# STABLE_RESOURCE_SAMPLE_MS=15000
# Tableau de bord graphique du lanceur (http://127.0.0.1:8789)
STABLE_LAUNCHER_GUI=1
STABLE_LAUNCHER_GUI_PORT=8789
# Serveur dev Vite (surveillé par le même lanceur)
LAUNCHER_DEV_ENABLED=1
LAUNCHER_DEV_PORT=5173
LAUNCHER_DEV_AUTO_START=0
LAUNCHER_DEV_AUTO_RESTART=1
# IP publique ou nom de domaine (DuckDNS…) pour jouer en 4G — regenere le cert après :
# npm run tls:stable
# STABLE_PUBLIC_HOST=88.123.45.67
# STABLE_PUBLIC_HOST=monjeu.duckdns.org
